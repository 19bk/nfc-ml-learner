# VHS tape file for recording the NFC-ML-Learner demo GIF
# Run with: vhs scripts/demo.tape

Output docs/demo.gif

Set Shell zsh
Set FontSize 16
Set Width 900
Set Height 520
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms

Type "# NFC-ML-Learner: Offline Edge ML for Rural Education"
Enter
Sleep 800ms

Type "python3 scripts/demo_simulate.py"
Sleep 500ms
Enter

Sleep 18s

Sleep 1s
